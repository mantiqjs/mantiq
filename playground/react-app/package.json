{
  "name": "playground-react",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run dev:backend & bun run dev:frontend & wait",
    "start": "bun run index.ts",
    "mantiq": "bun run mantiq.ts",
    "dev:backend": "bun run --watch index.ts",
    "dev:frontend": "bunx vite --clearScreen false",
    "build": "vite build && vite build --ssr src/ssr.tsx --outDir bootstrap/ssr"
  },
  "dependencies": {
    "@mantiq/auth": "workspace:*",
    "@mantiq/cli": "workspace:*",
    "@mantiq/core": "workspace:*",
    "@mantiq/database": "workspace:*",
    "@mantiq/events": "workspace:*",
    "@mantiq/filesystem": "workspace:*",
    "@mantiq/health": "workspace:*",
    "@mantiq/heartbeat": "workspace:*",
    "@mantiq/helpers": "workspace:*",
    "@mantiq/logging": "workspace:*",
    "@mantiq/mail": "workspace:*",
    "@mantiq/notify": "workspace:*",
    "@mantiq/queue": "workspace:*",
    "@mantiq/realtime": "workspace:*",
    "@mantiq/search": "workspace:*",
    "@mantiq/validation": "workspace:*",
    "@mantiq/vite": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "lucide-react": "^1.0.1",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
