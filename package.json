{
  "name": "mantiqjs",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "addons/*",
    "starters/*",
    "examples/*",
    "docs"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test packages/",
    "test:ci": "bun test packages/ --exclude '**/mssql*'",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "clean": "bun run --filter '*' clean",
    "publish:all": "for dir in packages/*/; do (cd \"$dir\" && npm publish --access public); done"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
