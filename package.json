{
  "name": "mantiqjs",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test packages/",
    "test:ci": "bun test packages/ --path-ignore-patterns '**/mssql*'",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "clean": "bun run --filter '*' clean",
    "publish:all": "for dir in packages/*/; do (cd \"$dir\" && npm publish --access public); done"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@mantiq/core": "workspace:*",
    "@mantiq/database": "workspace:*",
    "@mantiq/auth": "workspace:*",
    "@mantiq/cli": "workspace:*",
    "@mantiq/validation": "workspace:*",
    "@mantiq/helpers": "workspace:*",
    "@mantiq/filesystem": "workspace:*",
    "@mantiq/logging": "workspace:*",
    "@mantiq/events": "workspace:*",
    "@mantiq/queue": "workspace:*",
    "@mantiq/realtime": "workspace:*",
    "@mantiq/heartbeat": "workspace:*",
    "@mantiq/vite": "workspace:*",
    "@mantiq/mail": "workspace:*",
    "@mantiq/notify": "workspace:*"
  }
}
