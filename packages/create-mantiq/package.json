{
  "name": "create-mantiq",
  "version": "0.1.2",
  "description": "Scaffold a new MantiqJS application",
  "type": "module",
  "license": "MIT",
  "author": "Abdullah Khan",
  "homepage": "https://github.com/abdullahkhan/mantiq/tree/main/packages/create-mantiq",
  "repository": {
    "type": "git",
    "url": "https://github.com/abdullahkhan/mantiq.git",
    "directory": "packages/create-mantiq"
  },
  "bugs": {
    "url": "https://github.com/abdullahkhan/mantiq/issues"
  },
  "keywords": [
    "mantiq",
    "mantiqjs",
    "bun",
    "typescript",
    "framework",
    "create-mantiq"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "create-mantiq": "./src/index.ts"
  },
  "files": [
    "src/",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.7.0"
  }
}
