{
  "name": "@mantiq/events",
  "version": "0.7.12",
  "description": "Event dispatcher, listeners, observers, and broadcasting for MantiqJS",
  "type": "module",
  "license": "MIT",
  "author": "Abdullah Khan",
  "homepage": "https://github.com/mantiqjs/mantiq/tree/main/packages/events",
  "repository": {
    "type": "git",
    "url": "https://github.com/mantiqjs/mantiq.git",
    "directory": "packages/events"
  },
  "bugs": {
    "url": "https://github.com/mantiqjs/mantiq/issues"
  },
  "keywords": [
    "mantiq",
    "mantiqjs",
    "bun",
    "typescript",
    "framework",
    "events"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --packages=external",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@mantiq/database": "workspace:*",
    "@mantiq/auth": "workspace:*",
    "bun-types": "latest",
    "typescript": "^5.7.0",
    "@mantiq/core": "workspace:*"
  },
  "peerDependencies": {
    "@mantiq/core": "^0.5.0",
    "@mantiq/database": "^0.5.0",
    "@mantiq/auth": "^0.5.0"
  },
  "peerDependenciesMeta": {
    "@mantiq/database": {
      "optional": true
    },
    "@mantiq/auth": {
      "optional": true
    }
  },
  "mantiq": {
    "provider": "EventServiceProvider"
  }
}
