{
  "name": "@mantiq/events",
  "version": "0.0.1",
  "description": "Event dispatcher, listeners, observers, and broadcasting for MantiqJS",
  "type": "module",
  "main": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": { "@mantiq/core": "workspace:*" },
  "peerDependencies": { "@mantiq/database": "workspace:*", "@mantiq/auth": "workspace:*" },
  "peerDependenciesMeta": { "@mantiq/database": { "optional": true }, "@mantiq/auth": { "optional": true } },
  "devDependencies": { "@mantiq/database": "workspace:*", "@mantiq/auth": "workspace:*", "bun-types": "latest", "typescript": "^5.7.0" }
}
