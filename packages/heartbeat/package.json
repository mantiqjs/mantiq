{
  "name": "@mantiq/heartbeat",
  "version": "0.0.1",
  "description": "Observability, APM & queue monitoring for MantiqJS",
  "type": "module",
  "main": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "test": "bun test",
