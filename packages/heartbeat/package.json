  },
  "dependencies": {
    "@mantiq/core": "workspace:*",
    "@mantiq/cli": "workspace:*",
    "@mantiq/queue": "workspace:*",
    "@mantiq/events": "workspace:*",
    "@mantiq/database": "workspace:*",
    "@mantiq/logging": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.7.0"
  }
}
