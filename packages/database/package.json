    "mssql": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "bun-types": "latest",
    "mssql": "^11.0.0",
    "mysql2": "^3.14.1",
    "pg": "^8.13.3",
    "typescript": "^5.7.0"
  }
