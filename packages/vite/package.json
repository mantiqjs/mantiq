{
  "name": "@mantiq/vite",
  "version": "0.7.10",
  "description": "Vite dev server & manifest integration",
  "type": "module",
  "license": "MIT",
  "author": "Abdullah Khan",
  "homepage": "https://github.com/mantiqjs/mantiq/tree/main/packages/vite",
  "repository": {
    "type": "git",
    "url": "https://github.com/mantiqjs/mantiq.git",
    "directory": "packages/vite"
  },
  "bugs": {
    "url": "https://github.com/mantiqjs/mantiq/issues"
  },
  "keywords": [
    "mantiq",
    "mantiqjs",
    "bun",
    "typescript",
    "framework",
    "vite"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "bun": "./src/plugins/mantiq.ts",
      "default": "./dist/mantiq.js"
    }
  },
  "files": [
    "src/",
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --packages=external --format esm && bun build ./src/plugins/mantiq.ts --outfile ./dist/mantiq.js --target node --packages=external --format esm",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "@mantiq/core": "workspace:*"
  },
  "peerDependencies": {
    "@mantiq/core": "^0.5.0",
    "vite": ">=8.0.0"
  },
  "mantiq": {
    "provider": "ViteServiceProvider"
  }
}
