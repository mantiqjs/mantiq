    "@mantiq/events": "^0.5.0",
    "@mantiq/filesystem": "^0.5.0",
    "@mantiq/health": "^0.5.0",
    "@mantiq/heartbeat": "^0.5.0",
    "@mantiq/helpers": "^0.5.0",
    "@mantiq/logging": "^0.5.0",
    "@mantiq/mail": "^0.5.0",
    "@mantiq/notify": "^0.5.0",
    "@mantiq/queue": "^0.5.0",
    "@mantiq/realtime": "^0.5.0",
    "@mantiq/search": "^0.5.0",
    "@mantiq/validation": "^0.5.0",
    "@mantiq/vite": "^0.5.0",
    "class-variance-authority": "^0.7.1",
