{
  "name": "studio-test",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run dev:backend & bun run dev:frontend & wait",
    "start": "bun run index.ts",
    "mantiq": "bun run mantiq.ts",
    "test": "bun test tests/",
    "dev:backend": "bun run --watch index.ts",
